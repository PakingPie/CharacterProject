    "m_SourceType": 1,
    "m_FunctionName": "GetMainLight",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if SHADERGRAPH_PREVIEW\nMainLightDir = normalize(float3(1, 1, 0));\nColor = float3(1, 1, 1);\nAttenuation = 1;\n#else\nMainLightDir = GetMainLight(0).direction;\nColor = GetMainLight(0).color;\nAttenuation = GetMainLight(0).shadowAttenuation;\n#endif"
}

